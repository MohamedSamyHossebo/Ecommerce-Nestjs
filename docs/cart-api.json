{
  "openapi": "3.0.3",
  "info": {
    "title": "E-Commerce Cart API",
    "description": "API documentation for the Cart module endpoints. All endpoints require Bearer token authentication.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Cart",
      "description": "Shopping cart management operations"
    }
  ],
  "paths": {
    "/cart": {
      "get": {
        "tags": ["Cart"],
        "summary": "Get user cart",
        "description": "Retrieves the authenticated user's cart with populated product details. If no cart exists, a new empty cart is created and returned.",
        "operationId": "getCart",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Cart retrieved successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CartResponse" },
                "example": {
                  "_id": "6690a1b2c3d4e5f6a7b8c9d0",
                  "user": "6690a1b2c3d4e5f6a7b8c9d1",
                  "items": [
                    {
                      "product": {
                        "_id": "6690a1b2c3d4e5f6a7b8c9d2",
                        "name": "Wireless Headphones",
                        "price": 59.99,
                        "stock": 25
                      },
                      "quantity": 2,
                      "pricePerUnit": 59.99,
                      "subTotal": 119.98
                    }
                  ],
                  "totalPrice": 119.98,
                  "totalItems": 0,
                  "createdAt": "2026-07-10T12:00:00.000Z",
                  "updatedAt": "2026-07-10T12:30:00.000Z"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized — missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "statusCode": 401,
                  "message": "Unauthorized"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Cart"],
        "summary": "Add item to cart",
        "description": "Adds a product to the authenticated user's cart. If the product already exists in the cart, its quantity is incremented. Validates product existence and stock availability. Creates a new cart if the user doesn't have one.",
        "operationId": "addToCart",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddToCartDTO" },
              "example": {
                "product": "6690a1b2c3d4e5f6a7b8c9d2",
                "quantity": 2
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product added to cart successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CartResponse" },
                "example": {
                  "_id": "6690a1b2c3d4e5f6a7b8c9d0",
                  "user": "6690a1b2c3d4e5f6a7b8c9d1",
                  "items": [
                    {
                      "product": {
                        "_id": "6690a1b2c3d4e5f6a7b8c9d2",
                        "name": "Wireless Headphones",
                        "price": 59.99,
                        "stock": 25
                      },
                      "quantity": 2,
                      "pricePerUnit": 59.99,
                      "subTotal": 119.98
                    }
                  ],
                  "totalPrice": 119.98,
                  "totalItems": 0,
                  "createdAt": "2026-07-10T12:00:00.000Z",
                  "updatedAt": "2026-07-10T12:30:00.000Z"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request — insufficient stock or invalid input",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "notEnoughStock": {
                    "summary": "Insufficient stock",
                    "value": {
                      "statusCode": 400,
                      "message": "Not Enough Stock , the amount of stock is 5"
                    }
                  },
                  "validationError": {
                    "summary": "Validation failed",
                    "value": {
                      "statusCode": 400,
                      "message": [
                        "Product ID is Required",
                        "Quantity Must Be At Least 1"
                      ],
                      "error": "Bad Request"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized — missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "statusCode": 401,
                  "message": "Unauthorized"
                }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "statusCode": 404,
                  "message": "Product Not Found"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Cart"],
        "summary": "Clear cart",
        "description": "Removes all items from the authenticated user's cart and resets the total price to 0.",
        "operationId": "clearCart",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Cart cleared successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CartResponse" },
                "example": {
                  "_id": "6690a1b2c3d4e5f6a7b8c9d0",
                  "user": "6690a1b2c3d4e5f6a7b8c9d1",
                  "items": [],
                  "totalPrice": 0,
                  "totalItems": 0,
                  "createdAt": "2026-07-10T12:00:00.000Z",
                  "updatedAt": "2026-07-10T13:00:00.000Z"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized — missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "statusCode": 401,
                  "message": "Unauthorized"
                }
              }
            }
          },
          "404": {
            "description": "Cart not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "statusCode": 404,
                  "message": "Cart Not Found"
                }
              }
            }
          }
        }
      }
    },
    "/cart/{productId}": {
      "patch": {
        "tags": ["Cart"],
        "summary": "Remove item from cart",
        "description": "Removes a specific product from the authenticated user's cart by product ID and recalculates the cart total.",
        "operationId": "removeFromCart",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "description": "The MongoDB ObjectId of the product to remove from the cart",
            "schema": {
              "type": "string",
              "example": "6690a1b2c3d4e5f6a7b8c9d2"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item removed from cart successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CartResponse" },
                "example": {
                  "_id": "6690a1b2c3d4e5f6a7b8c9d0",
                  "user": "6690a1b2c3d4e5f6a7b8c9d1",
                  "items": [],
                  "totalPrice": 0,
                  "totalItems": 0,
                  "createdAt": "2026-07-10T12:00:00.000Z",
                  "updatedAt": "2026-07-10T13:00:00.000Z"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized — missing or invalid Bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "statusCode": 401,
                  "message": "Unauthorized"
                }
              }
            }
          },
          "404": {
            "description": "Cart not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "statusCode": 404,
                  "message": "Cart Not Found"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token obtained from the authentication endpoint"
      }
    },
    "schemas": {
      "AddToCartDTO": {
        "type": "object",
        "required": ["product", "quantity"],
        "properties": {
          "product": {
            "type": "string",
            "description": "MongoDB ObjectId of the product to add",
            "example": "6690a1b2c3d4e5f6a7b8c9d2"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of units to add (must be at least 1)",
            "example": 2
          }
        }
      },
      "PopulatedProduct": {
        "type": "object",
        "description": "Product details populated from the Product collection",
        "properties": {
          "_id": {
            "type": "string",
            "description": "Product ObjectId",
            "example": "6690a1b2c3d4e5f6a7b8c9d2"
          },
          "name": {
            "type": "string",
            "description": "Product name",
            "example": "Wireless Headphones"
          },
          "price": {
            "type": "number",
            "description": "Product unit price",
            "example": 59.99
          },
          "stock": {
            "type": "integer",
            "description": "Available stock quantity",
            "example": 25
          }
        }
      },
      "CartItem": {
        "type": "object",
        "description": "An individual item in the cart",
        "properties": {
          "product": {
            "oneOf": [
              { "type": "string", "description": "Product ObjectId (when not populated)" },
              { "$ref": "#/components/schemas/PopulatedProduct" }
            ],
            "description": "Reference to the product (populated in responses)"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of units in the cart",
            "example": 2
          },
          "pricePerUnit": {
            "type": "number",
            "minimum": 0,
            "description": "Price per single unit at the time of adding",
            "example": 59.99
          },
          "subTotal": {
            "type": "number",
            "minimum": 0,
            "description": "quantity × pricePerUnit",
            "example": 119.98
          }
        }
      },
      "CartResponse": {
        "type": "object",
        "description": "The user's shopping cart",
        "properties": {
          "_id": {
            "type": "string",
            "description": "Cart ObjectId",
            "example": "6690a1b2c3d4e5f6a7b8c9d0"
          },
          "user": {
            "type": "string",
            "description": "User ObjectId (owner of the cart)",
            "example": "6690a1b2c3d4e5f6a7b8c9d1"
          },
          "items": {
            "type": "array",
            "description": "List of cart items with populated product details",
            "items": { "$ref": "#/components/schemas/CartItem" }
          },
          "totalPrice": {
            "type": "number",
            "minimum": 0,
            "description": "Sum of all item subTotals",
            "example": 119.98
          },
          "totalItems": {
            "type": "integer",
            "minimum": 0,
            "description": "Total number of items in cart",
            "example": 0
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Cart creation timestamp",
            "example": "2026-07-10T12:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2026-07-10T12:30:00.000Z"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "description": "HTTP status code",
            "example": 400
          },
          "message": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ],
            "description": "Error message or array of validation messages"
          },
          "error": {
            "type": "string",
            "description": "Error type label (present on validation errors)",
            "example": "Bad Request"
          }
        }
      }
    }
  }
}
